<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Portfolio</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            line-height: 1.6;
            color: #333;
        }

        /* Navbar */
        header {
            background: #222;
            color: #fff;
            padding: 15px 20px;
            position: sticky;
            top: 0;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav ul {
            display: flex;
            list-style: none;
        }

        nav ul li {
            margin-left: 20px;
        }

        nav ul li a {
            color: #fff;
            text-decoration: none;
            font-weight: bold;
        }

        nav ul li a:hover {
            color: #00adb5;
        }

        /* Hero Section */
        .hero {
            background: #00adb5;
            color: white;
            text-align: center;
            padding: 80px 20px;
        }

        .hero h1 {
            font-size: 2.5rem;
        }

        .hero p {
            margin-top: 10px;
            font-size: 1.2rem;
        }

        /* Sections */
        section {
            padding: 60px 20px;
            max-width: 1000px;
            margin: auto;
        }

        section h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #00adb5;
        }

        /* About */
        .about p {
            text-align: center;
            font-size: 1.1rem;
        }

        /* Skills */
        .skills {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .skill {
            background: #f4f4f4;
            padding: 20px;
            text-align: center;
            border-radius: 8px;
        }

        /* Projects */
        .projects {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .project {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
        }

        /* Contact */
        .contact {
            text-align: center;
        }

        .contact a {
            display: inline-block;
            margin-top: 10px;
            color: #00adb5;
            text-decoration: none;
            font-weight: bold;
        }

        /* Footer */
        footer {
            background: #222;
            color: #fff;
            text-align: center;
            padding: 15px;
            margin-top: 40px;
        }

        /* Responsive Navbar */
        @media (max-width: 600px) {
            nav {
                flex-direction: column;
            }

            nav ul {
                flex-direction: column;
                margin-top: 10px;
            }

            nav ul li {
                margin: 10px 0;
            }
        }
    </style>
</head>

<body>

<header>
    <nav>
        <h2>MyPortfolio</h2>
        <ul>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
</header>

<div class="hero">
    <h1>Hello, I'm Tamil</h1>
    <p>Web Developer | Student | Tech Enthusiast</p>
</div>

<section id="about" class="about">
    <h2>About Me</h2>
    <p>
        I am a passionate learner interested in web development and software
        engineering. I enjoy building clean and responsive websites.
    </p>
</section>

<section id="skills">
    <h2>Skills</h2>
    <div class="skills">
        <div class="skill">HTML</div>
        <div class="skill">CSS</div>
        <div class="skill">JavaScript</div>
        <div class="skill">C / C++</div>
        <div class="skill">Python</div>
        <div class="skill">React (Basic)</div>
    </div>
</section>

<section id="projects">
    <h2>Projects</h2>
    <div class="projects">
        <div class="project">
            <h3>Portfolio Website</h3>
            <p>Responsive personal portfolio using HTML & CSS.</p>
        </div>
        <div class="project">
            <h3>Quiz App</h3>
            <p>Simple quiz application using JavaScript.</p>
        </div>
        <div class="project">
            <h3>Attendance System</h3>
            <p>Basic student attendance management system.</p>
        </div>
    </div>
</section>

<section id="contact" class="contact">
    <h2>Contact Me</h2>
    <p>Email: tamil@example.com</p>
    <a href="#">LinkedIn Profile</a>
</section>

<footer>
    <p>© 2025 Tamil. All Rights Reserved.</p>
</footer>

</body>
</html>
